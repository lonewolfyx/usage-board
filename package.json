{
    "name": "usage-board",
    "type": "module",
    "version": "2.0.0",
    "packageManager": "pnpm@10.33.0",
    "description": "An all-in-one dashboard to quickly analyze token usage from local json files",
    "license": "MIT",
    "homepage": "https://github.com/lonewolfyx/usage-board",
    "bugs": {
        "url": "https://github.com/lonewolfyx/usage-board/issues"
    },
    "keywords": [
        "ai",
        "gemini",
        "codex",
        "claude",
        "claude-code",
        "token-usage",
        "analysis",
        "usage-board"
    ],
    "bin": {
        "usage-board": "./bin/cli.js",
        "ub": "./bin/cli.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "nuxt build && tsdown && rm ./dist/nitro.json",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "typecheck": "nuxt typecheck",
        "lint": "eslint .",
        "lint:fix": "eslint --fix",
        "dev:cli": "tsdown -w",
        "test": "vitest",
        "prepare": "nuxt prepare && simple-git-hooks",
        "prepublishOnly": "pnpm build"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org",
        "access": "public"
    },
    "dependencies": {
        "cac": "^7.0.0",
        "crossws": "^0.4.5",
        "glob": "^13.0.6"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^8.2.0",
        "@iconify-json/lucide": "^1.2.102",
        "@iconify-json/mdi": "^1.2.3",
        "@iconify-json/ri": "^1.2.10",
        "@iconify-json/solar": "^1.2.5",
        "@iconify-json/svg-spinners": "^1.2.4",
        "@internationalized/date": "^3.12.1",
        "@lonewolfyx/utils": "^0.0.2",
        "@nuxt/content": "^3.12.0",
        "@nuxt/eslint": "^1.15.2",
        "@nuxt/icon": "^2.2.1",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/vue-table": "^8.21.3",
        "@types/node": "^25.6.0",
        "@types/ws": "^8.18.1",
        "@unovis/ts": "^1.6.4",
        "@unovis/vue": "^1.6.4",
        "@vee-validate/zod": "^4.15.1",
        "@vueuse/core": "^14.2.1",
        "@vueuse/nuxt": "^14.2.1",
        "chokidar": "^5.0.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "embla-carousel-vue": "^8.6.0",
        "eslint": "^10.2.0",
        "get-port-please": "^3.2.0",
        "lint-staged": "^16.4.0",
        "lucide-vue-next": "^0.545.0",
        "nuxt": "^4.4.2",
        "open": "^11.0.0",
        "path-type": "^6.0.0",
        "picocolors": "^1.1.1",
        "reka-ui": "^2.9.5",
        "shadcn-nuxt": "^2.6.2",
        "simple-git-hooks": "^2.13.1",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.2",
        "ts-node": "^10.9.2",
        "tsdown": "^0.21.8",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.2",
        "vaul-vue": "^0.4.1",
        "vee-validate": "^4.15.1",
        "vitest": "^4.1.4",
        "vue": "^3.5.26",
        "vue-input-otp": "^0.3.2",
        "vue-router": "^4.6.4",
        "vue-sonner": "^2.0.9",
        "ws": "^8.20.0",
        "zod": "3.25.76"
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged",
        "commit-msg": "node scripts/verify-commit.js"
    },
    "lint-staged": {
        "*": "eslint --fix"
    }
}
