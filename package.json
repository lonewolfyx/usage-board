{
    "name": "usage-board",
    "type": "module",
    "description": "An all-in-one dashboard to quickly analyze token usage from local json files",
    "packageManager": "pnpm@10.33.0",
    "homepage": "https://github.com/lonewolfyx/usage-board",
    "bugs": {
        "url": "https://github.com/lonewolfyx/usage-board/issues"
    },
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "typecheck": "nuxt typecheck",
        "lint": "eslint .",
        "lint:fix": "eslint --fix",
        "prepare": "simple-git-hooks"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.2.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-vue-next": "^0.545.0",
        "reka-ui": "^2.9.5",
        "tailwindcss": "^4.2.2",
        "vue": "^3.5.26",
        "vue-router": "^4.6.4"
    },
    "devDependencies": {
        "@nuxt/content": "^3.12.0",
        "@nuxt/eslint": "^1.15.2",
        "@nuxt/icon": "^2.2.1",
        "@vueuse/nuxt": "^14.2.1",
        "eslint": "^10.2.0",
        "lint-staged": "^16.4.0",
        "nuxt": "^4.4.2",
        "picocolors": "^1.1.1",
        "shadcn-nuxt": "^2.6.2",
        "simple-git-hooks": "^2.13.1",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.2"
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged",
        "commit-msg": "node scripts/verify-commit.js"
    },
    "license": "MIT",
    "lint-staged": {
        "*": "eslint --fix"
    }
}
